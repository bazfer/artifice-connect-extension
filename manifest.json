{
  "manifest_version": 3,
  "name": "Artífice Connect",
  "version": "1.0.0",
  "description": "Connect your browser to your AI assistant. Let your agent see and interact with web pages on your behalf.",
  "homepage_url": "https://artificeia.mx",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["debugger", "tabs", "activeTab", "storage", "alarms"],
  "host_permissions": [
    "wss://relay.artificeia.mx/*",
    "https://relay.artificeia.mx/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Artífice Connect (click to share/unshare tab)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": { "page": "options.html", "open_in_tab": true }
}
